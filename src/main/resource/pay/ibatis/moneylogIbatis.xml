<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap
        PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN"
        "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="db">
    <typeAlias alias="Moneylog" type="com.lxtx.pay.pojo.Moneylog"/>

    <insert id="Moneylog.insert" parameterClass="Moneylog">
        insert into moneylog (id, type, sceneinfo, frontmoney, money, queenmoney, details, createtime, appid, notes)
        values (null, #Type#, #SceneInfo#, #FrontMoney#, #Money#, #QueenMoney#, #Details#, #CreateTime#, #AppId#,
                #Notes#)
    </insert>
    <select id="Moneylog.getAll" resultClass="Moneylog">
        select *
        from moneylog
    </select>


    <select id="Moneylog.queryMoneyLogPageList" parameterClass="com.lxtx.pay.dto.MoneyLogReqDTO"
            resultClass="com.lxtx.pay.vo.MoneyLogVO">
        select id, type, sceneinfo, frontmoney, money, queenmoney, createtime, appid, orderid, logid,notes
        from moneylog m
        where AppId = #appId#
        <isNotEmpty property="id" prepend="and">
            Id=#id#
        </isNotEmpty>
        <isNotEmpty property="type" prepend="and">
            Type=#type#
        </isNotEmpty>
        <isNotEmpty property="sceneInfo" prepend="and">
            SceneInfo=#sceneInfo#
        </isNotEmpty>
        <isNotEmpty prepend="and" property="startCreateTime">
            m.CreateTime &gt;= #startCreateTime#
        </isNotEmpty>
        <isNotEmpty prepend="and" property="endCreateTime">
            m.CreateTime &lt;= #endCreateTime#
        </isNotEmpty>
        <isNotEmpty property="orderId" prepend="and">
            OrderId=#orderId#
        </isNotEmpty>
        <isNotEmpty property="money" prepend="and">
            Money=#money#
        </isNotEmpty>
        order by CreateTime desc
        <isNotEmpty property="rowIndex">
            limit $rowIndex$,$limit$
        </isNotEmpty>
    </select>
    <select id="Moneylog.queryMoneyLogPageListCount" parameterClass="com.lxtx.pay.dto.MoneyLogReqDTO" resultClass="int">
        select count(Id) from moneylog m
        where AppId = #appId#
        <isNotEmpty property="id" prepend="and">
            Id=#id#
        </isNotEmpty>
        <isNotEmpty property="type" prepend="and">
            Type=#type#
        </isNotEmpty>
        <isNotEmpty property="sceneInfo" prepend="and">
            SceneInfo=#sceneInfo#
        </isNotEmpty>
        <isNotEmpty prepend="and" property="startCreateTime">
            m.CreateTime &gt;= #startCreateTime#
        </isNotEmpty>
        <isNotEmpty prepend="and" property="endCreateTime">
            m.CreateTime &lt;= #endCreateTime#
        </isNotEmpty>
        <isNotEmpty property="orderId" prepend="and">
            OrderId=#orderId#
        </isNotEmpty>
        <isNotEmpty property="money" prepend="and">
            Money=#money#
        </isNotEmpty>
    </select>

    <select id="Moneylog.exportExcelMoneyLogList" resultClass="com.lxtx.pay.vo.MoneyLogExportVO"
            parameterClass="com.lxtx.pay.dto.MoneyLogReqDTO">
        select id, type, sceneinfo, frontmoney, money, queenmoney, createtime, appid, orderid, logid
        from moneylog m
        where AppId = #appId#
        <isNotEmpty property="id" prepend="and">
            Id=#id#
        </isNotEmpty>
        <isNotEmpty property="type" prepend="and">
            Type=#type#
        </isNotEmpty>
        <isNotEmpty property="sceneInfo" prepend="and">
            SceneInfo=#sceneInfo#
        </isNotEmpty>
        <isNotEmpty prepend="and" property="startCreateTime">
            m.CreateTime &gt;= #startCreateTime#
        </isNotEmpty>
        <isNotEmpty prepend="and" property="endCreateTime">
            m.CreateTime &lt;= #endCreateTime#
        </isNotEmpty>
        <isNotEmpty property="orderId" prepend="and">
            OrderId=#orderId#
        </isNotEmpty>
        <isNotEmpty property="money" prepend="and">
            Money=#money#
        </isNotEmpty>
        order by CreateTime desc
        <isNotEmpty property="rowIndex">
            limit $rowIndex$,$limit$
        </isNotEmpty>
    </select>

</sqlMap>
