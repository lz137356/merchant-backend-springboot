<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap
        PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN"
        "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="db">

    <typeAlias alias="cpstat" type="com.lxtx.pay.pojo.Cpstat"/>
    <resultMap id="cpstatmap" class="com.lxtx.pay.pojo.Cpstat">
        <result property="AppId" column="AppId"/>
        <result property="StatDay" column="StatDay"/>
        <result property="PayAmount" column="PayAmount"/>
        <result property="PayFee" column="PayFee"/>
        <result property="WithdrawAmount" column="WithdrawAmount"/>
        <result property="WithdrawFee" column="WithdrawFee"/>
        <result property="key" column="Key"/>


    </resultMap>

    <select id="Cpstat.queryAllByAppid" resultClass="cpstat" parameterClass="java.util.Map">
        select * from cpstat
        <dynamic prepend="where">
            <isNotEmpty prepend="and" property="appId">
                AppId=#appId#
            </isNotEmpty>
            <isNotEmpty prepend="and" property="startDay">
                StatDay &gt;= #startDay#
            </isNotEmpty>
            <isNotEmpty prepend="and" property="endDay">
                StatDay &lt;= #endDay#
            </isNotEmpty>



        </dynamic>

        order by StatDay desc
        <isNotEmpty property="rowIndex">
            limit $rowIndex$,$limit$
        </isNotEmpty>
    </select>
    <select id="Cpstat.queryAllByAppidcount" resultClass="int" parameterClass="java.util.Map">
        select count(Id) from cpstat
        <dynamic prepend="where">
            <isNotEmpty prepend="and" property="appId">
                AppId=#appId#
            </isNotEmpty>
            <isNotEmpty prepend="and" property="startDay">
                StatDay &gt;= #startDay#
            </isNotEmpty>
            <isNotEmpty prepend="and" property="endDay">
                StatDay &lt;= #endDay#
            </isNotEmpty>
        </dynamic>
    </select>
    <select id="Cpstat.queryByDate" resultMap="cpstatmap">
        select * from cpstat left join cpinfo c on cpstat.AppId = c.AppId where cpstat.AppId=#appId# and StatDay=#statday#
    </select>


</sqlMap>