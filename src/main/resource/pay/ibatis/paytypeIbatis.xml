<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE sqlMap
        PUBLIC "-//iBATIS.com//DTD SQL Map 2.0//EN"
        "http://ibatis.apache.org/dtd/sql-map-2.dtd">

<sqlMap namespace="db">
    <typeAlias alias="paytype" type="com.lxtx.pay.pojo.PayType"/>

    <select id="PayType.getAll" resultClass="paytype">
   	select * from paytype
   </select>
    <select id="PayType.select" resultClass="paytype">
        select * from paytype where Id=#id#
    </select>
    <insert id="PayType.insert" parameterClass="PayType">
        insert into paytype values (null,#name#,#params#,#status#,#feefix#,#feerate#,#totalfee#,#sort#,#types#,#worktime#,#range#,#createtime#,#currency#)
    </insert>
    <delete id="PayType.deleteByPrimaryKey" parameterClass="int">
        delete from paytype where Id=#id#
    </delete>
    <update id="PayType.update" parameterClass="PayType">
        update paytype p set p.Name=#name#,Params=#params#
                           ,Status=#status#,FeeFix=#feefix#
                           ,FeeRate=#feerate#,Sort=#sort#
                           ,Types=#types#,WorkTime=#worktime#
                           ,`Range`=#range#,Currency=#currency#
        where Id=#id#
    </update>
</sqlMap>
